# Copiez ce fichier en .env et adaptez les valeurs, ou exportez ces variables
# directement dans votre environnement / configuration serveur (gunicorn, etc.)

DJANGO_SECRET_KEY=changez-cette-cle-en-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# --- Base de données ---
# Mettre USE_SQLITE=True pour tester rapidement sans MySQL (déconseillé en prod)
USE_SQLITE=False
DB_NAME=plastique_erp
DB_USER=plastique_user
DB_PASSWORD=plastique_password
DB_HOST=127.0.0.1
DB_PORT=3306

# Mot de passe root MySQL (utilisé uniquement par docker-compose.yml, pas par Django)
DB_ROOT_PASSWORD=root_password_a_changer

# --- Paramètres métier ---
NOM_ENTREPRISE=Chnoui ERP
SEUIL_STOCK_FAIBLE_KG=500
JOURS_ALERTE_CHEQUE=5
